# reverse of the list_
li = [-2, 1, -5] 
rev = []
for i in li:
    rev.append(i*-1)
print(f"Reversed list is {rev}")


#  Write a function that takes a number n and returns the sum of 
# every number from 1 to n (e.g., n=3 returns 1+2+3 = 6).
sum = 0
user= int(input("Enter a number: "))
for i in range(user+1):
    sum = sum + i
print(f"The sum of all smaller number is: {sum}")


