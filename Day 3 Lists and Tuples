# Write a function that returns the sum of all numbers in a list.
lis = []
lis = int(input("Enter number in list: "))
sum = 0
for i in lis:
    sum = sum + i
print(f"The sum of all numbers in list is: {sum}") 


# Given a list of strings, return a new list containing only strings longer than 5 characters
str_list = ["green", "full", "natural", "thomas"]
a = []
for i in str_list:
    if len(i) > 5:
        a.append(i)
print(a)



